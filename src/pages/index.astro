---
import Menu from '../components/Menu.astro';
import FoodCard from '../components/FoodCard.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import '../Styles/custom.css';
import leonImg from '../assets/bullterrier.png';
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Topicos Avanzados De Programacion</title>
</head>
<body>
<ParticleBackground />

<Menu>
    <div class="hero-section">
        <div class="hero-text">
            <h1>Topicos Avanzados De Programacion</h1>
            <p>Me dan miedo las mujeres</p>
        </div>
        <img src={leonImg.src} alt="Houston el astronauta" class="hero-image" />
    </div>

    <div class="cards-grid">
        <FoodCard
                titulo="Algoritmos al Ajillo"
                descripcion="Una mezcla de búsqueda binaria con un toque de ajo y especias."
                precio="$120.00"
                imagen="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?q=80&w=800&auto=format&fit=crop"
                detalles="Este platillo está inspirado en la eficiencia de la búsqueda binaria. Primero cortamos los ingredientes a la mitad, luego otra vez a la mitad, hasta llegar a la porción perfecta. Viene acompañado de una salsa de ajo que te dejará un aliento O(1)."
        />

        <FoodCard
                titulo="Estructuras en Salsa"
                descripcion="Árboles binarios bañados en salsa verde tradicional."
                precio="$95.00"
                imagen="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?q=80&w=800&auto=format&fit=crop"
                detalles="Nuestros árboles binarios son cultivados orgánicamente. Cada nodo contiene un sabor distinto y están perfectamente balanceados (como un árbol AVL) para que tu digestión no sufra. La salsa verde está picosita."
        />

        <FoodCard
                titulo="Query de Mariscos"
                descripcion="Una consulta compleja de camarones, pulpo y almejas."
                precio="$180.00"
                imagen="https://images.unsplash.com/photo-1606850780554-b55ea4dd0b70?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                detalles="Este platillo ejecuta un INNER JOIN entre los mejores mariscos de la costa y una base de arroz blanco. Está indexado para que el sabor llegue a tu paladar en milisegundos. ¡Cuidado con las inyecciones de picante!"
        />

        <FoodCard
                titulo="Pasta Firewall"
                descripcion="Espagueti con una barrera de queso parmesano contra el hambre."
                precio="$110.00"
                imagen="https://images.unsplash.com/photo-1473093226795-af9932fe5856?q=80&w=800&auto=format&fit=crop"
                detalles="Nuestra pasta actúa como un proxy inverso: filtra el hambre y solo deja pasar la satisfacción. Viene con una capa de seguridad de albóndigas encriptadas en salsa pomodoro. Nadie podrá hackear tu apetito."
        />

        <FoodCard
                titulo="Tacos de Ensamblador"
                descripcion="Tacos de bajo nivel, directo al hardware del estómago."
                precio="$85.00"
                imagen="https://images.unsplash.com/photo-1504674900247-0877df9cc836?q=80&w=800&auto=format&fit=crop"
                detalles="Estos tacos no usan librerías externas. Son de pastor puro programado en registro por registro. Cada bocado mueve 8 bits de sabor directamente a tu memoria central. Incluye interrupciones de cebolla y cilantro."
        />

        <FoodCard
                titulo="Cloud Burger"
                descripcion="Hamburguesa distribuida en múltiples capas de sabor."
                precio="$145.00"
                imagen="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=800&auto=format&fit=crop"
                detalles="Una hamburguesa escalable que se adapta a tu hambre. Cuenta con alta disponibilidad de tocino y un balanceador de carga de queso cheddar. Si el hambre aumenta, ¡añadimos otra capa automáticamente!"
        />

        <FoodCard
                titulo="Ramen Recursivo"
                descripcion="Un bucle infinito de fideos y sabor que se llama a sí mismo."
                precio="$135.00"
                imagen="https://images.unsplash.com/photo-1569718212165-3a8278d5f624?q=80&w=800&auto=format&fit=crop"
                detalles="Este platillo se sirve en un tazón que parece no tener fin. La experiencia es recursiva: cada bocado te lleva a otro bocado más profundo hasta que alcanzas el caso base: el fondo del plato. Si no tienes cuidado, podrías sufrir un Stack Overflow de sabor."
        />

        <FoodCard
                titulo="Sopa de Kernel"
                descripcion="Sopa monolítica compilada con los mejores módulos del huerto."
                precio="$80.00"
                imagen="https://images.unsplash.com/photo-1547592166-23ac45744acd?q=80&w=800&auto=format&fit=crop"
                detalles="Una sopa optimizada para cualquier hardware digestivo. Es modular, así que puedes añadirle 'parches' de chile o limón en tiempo de ejecución sin necesidad de reiniciar tu comida. Es de código abierto, así que si te gusta, te pasamos la receta (el source code)."
        />

        <FoodCard
                titulo="Sushi en Paralelo"
                descripcion="Rollos distribuidos que se procesan simultáneamente en tu paladar."
                precio="$165.00"
                imagen="https://images.unsplash.com/photo-1579871494447-9811cf80d66c?q=80&w=800&auto=format&fit=crop"
                detalles="Olvídate del procesamiento secuencial. Estos rollos están diseñados para ser consumidos en hilos separados. Cada pieza llega a tus papilas gustativas mediante una arquitectura de alta disponibilidad, garantizando que el sabor no tenga cuellos de botella."
        />
    </div>
</Menu>
</body>
</html>

<style>
    .hero-section {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        gap: 4rem;
        padding: 4rem 2rem;
        max-width: 1000px;
        margin: 0 auto;
        position: relative;
        z-index: 10;
    }

    .hero-text {
        flex: 1;
        text-align: left;
    }

    .hero-section h1 {
        font-size: 3.5rem;
        font-weight: 800;
        color: #111827;
        margin-bottom: 0.5rem;
        line-height: 1.2;
    }

    .hero-section p {
        font-size: 1.5rem;
        color: #4b5563;
        margin: 0;
    }

    .hero-image {
        width: 450px;
        height: 450px;
        flex-shrink: 0;
        object-fit: contain;
    }

    .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
        z-index: 10;
    }

    @media (max-width: 768px) {
        .hero-section {
            flex-direction: column-reverse;
            text-align: center;
            gap: 2rem;
        }

        .hero-text {
            text-align: center;
        }
    }
</style>