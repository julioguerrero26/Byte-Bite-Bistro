---
---
<div class="app-container">
    <header class="topbar">
        <button id="toggle-sidebar" class="menu-btn">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>
        <div class="logo">
            <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="2" y1="12" x2="22" y2="12"></line>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
        </div>
    </header>

    <div class="main-wrapper">
        <aside id="sidebar" class="sidebar">
            <nav class="menu">
                <a href="#">
                    <span>Ver Menú Principal</span>
                    <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </a>
            </nav>
        </aside>

        <main class="content">
            <slot />
        </main>
    </div>
</div>

<style>
    .app-container {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        background: transparent;
    }

    .topbar {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 60px;
        display: flex;
        align-items: center;
        padding: 0 1rem;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
        z-index: 30;
        box-sizing: border-box;
    }

    .menu-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        margin-right: 1.5rem;
        padding: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        transition: background-color 0.2s ease;
        color: #1a1a1a;
    }

    .menu-btn:hover {
        background: rgba(255, 255, 255, 0.3);
    }

    .logo {
        display: flex;
        align-items: center;
        color: #1a1a1a;
    }

    .main-wrapper {
        display: flex;
        flex: 1;
        width: 100%;
        height: 100%;
    }

    .sidebar {
        width: 260px;
        height: 100%;
        padding-top: 80px;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-right: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 4px 0 30px rgba(0, 0, 0, 0.05);
        transition: transform 0.3s ease, width 0.3s ease, opacity 0.2s ease;
        flex-shrink: 0;
        z-index: 20;
        box-sizing: border-box;
    }

    .sidebar.collapsed {
        width: 0;
        transform: translateX(-100%);
        opacity: 0;
        border-right: none;
    }

    .menu {
        display: flex;
        flex-direction: column;
        padding-top: 1rem;
    }

    .menu a {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.5rem;
        text-decoration: none;
        color: #1a1a1a;
        font-weight: 600;
        transition: background-color 0.2s ease;
    }

    .menu a:hover {
        background: rgba(255, 255, 255, 0.4);
    }

    .content {
        flex: 1;
        height: 100%;
        padding: 80px 2rem 2rem 2rem;
        overflow-y: auto;
        position: relative;
        z-index: 10;
        box-sizing: border-box;
    }
</style>

<script>
    const toggleBtn = document.getElementById('toggle-sidebar');
    const sidebar = document.getElementById('sidebar');

    if (toggleBtn && sidebar) {
        toggleBtn.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
        });
    }
</script>