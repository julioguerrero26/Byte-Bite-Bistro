---
// src/components/FoodCard.astro
interface Props {
    id?: string;
    titulo: string;
    descripcion: string;
    precio: string;
    imagen: string;
    detalles: string;
    categoria: string;
    tags?: string[];
}

const { 
    titulo, 
    descripcion, 
    precio, 
    imagen, 
    detalles, 
    categoria, 
    tags = [],
    id = titulo.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").replace(/\s+/g, '-')
} = Astro.props;
---

<div class="card-wrapper" data-categoria={categoria}>
    <div class="food-card" data-id={id}>
        <div class="img-container">
            <img src={imagen} alt={titulo} loading="lazy" />
            <div class="img-overlay"></div>
            <span class="card-category-badge">{categoria}</span>
            <button class="quick-add-btn" title="Agregar al carrito" aria-label="Agregar al carrito">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none">
                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <path d="M16 10a4 4 0 0 1-8 0"></path>
                </svg>
                <span class="quick-add-plus">+</span>
            </button>
        </div>
        <div class="info">
            <div class="tags-container">
                {tags.map(tag => <span class="tag-badge">{tag}</span>)}
            </div>
            <h3 class="titulo">{titulo}</h3>
            <p class="desc">{descripcion}</p>
            <div class="card-footer">
                <span class="precio">{precio}</span>
                <span class="action-hint">Configurar &rarr;</span>
            </div>
        </div>
    </div>

    <dialog class="food-modal">
        <div class="modal-content glass-panel">
            <button class="close-btn" aria-label="Cerrar">&times;</button>
            <div class="modal-split">
                <div class="modal-image-col">
                    <img src={imagen} alt={titulo} class="modal-img" />
                    <div class="modal-img-overlay"></div>
                </div>
                <div class="modal-info-col">
                    <span class="modal-category">{categoria}</span>
                    <h2 class="modal-title">{titulo}</h2>
                    
                    <div class="modal-tags">
                        {tags.map(tag => <span class="tag-badge">{tag}</span>)}
                    </div>
                    
                    <span class="modal-precio">{precio}</span>
                    <p class="modal-desc">{detalles}</p>

                    <div class="compra-section">
                        <h4 class="opciones-title">Parámetros de Ejecución</h4>
                        <div class="compra-controls">
                            <div class="cantidad-selector">
                                <button class="qty-btn minus" type="button" aria-label="Disminuir">-</button>
                                <input type="number" class="qty-input" value="1" min="1" readonly />
                                <button class="qty-btn plus" type="button" aria-label="Aumentar">+</button>
                            </div>
                            <button class="btn-comprar" type="button">Compilar al Carrito</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </dialog>
</div>

<style>
    .card-wrapper {
        height: 100%;
        display: block;
    }

    .food-card {
        background: rgba(15, 23, 42, 0.92);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 100%;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
        position: relative;
        will-change: transform, opacity;
    }

    .food-card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 20px;
        padding: 1px;
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.4), rgba(6, 182, 212, 0));
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
        transition: opacity 0.3s ease;
        opacity: 0.5;
    }

    .food-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 30px rgba(99, 102, 241, 0.15);
        border-color: rgba(6, 182, 212, 0.3);
    }

    .food-card:hover::before {
        opacity: 1;
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.6), rgba(236, 72, 153, 0.2));
    }

    .img-container {
        width: 100%;
        height: 200px;
        overflow: hidden;
        position: relative;
        background: #090e1a;
    }

    .img-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .food-card:hover .img-container img {
        transform: scale(1.08);
    }

    .img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(8, 12, 20, 0.8) 0%, rgba(8, 12, 20, 0) 60%);
        pointer-events: none;
    }

    .card-category-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: rgba(15, 23, 42, 0.92);
        color: var(--brand-cyan);
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border: 1px solid rgba(6, 182, 212, 0.25);
    }

    .quick-add-btn {
        position: absolute;
        bottom: 15px;
        right: 15px;
        background: var(--brand-primary);
        color: white;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.4);
        z-index: 5;
    }

    .quick-add-btn:hover {
        background: var(--brand-cyan);
        transform: scale(1.1) rotate(90deg);
        box-shadow: 0 4px 15px rgba(6, 182, 212, 0.5);
    }

    .quick-add-plus {
        position: absolute;
        top: 2px;
        right: 8px;
        font-size: 0.75rem;
        font-weight: 800;
    }

    .info {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .tags-container {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-bottom: 8px;
    }

    .tag-badge {
        font-size: 0.65rem;
        background: rgba(99, 102, 241, 0.1);
        color: #a5b4fc;
        padding: 2px 8px;
        border-radius: 4px;
        font-family: 'Fira Code', monospace, system-ui;
        border: 1px solid rgba(99, 102, 241, 0.15);
    }

    .titulo {
        color: var(--text-primary) !important;
        margin: 0 0 6px 0 !important;
        font-size: 1.25rem !important;
        font-weight: 700 !important;
        line-height: 1.3 !important;
    }

    .desc {
        color: var(--text-secondary) !important;
        font-size: 0.875rem !important;
        margin: 0 0 1.25rem 0 !important;
        line-height: 1.5 !important;
        flex-grow: 1;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: auto;
    }

    .precio {
        color: var(--brand-cyan) !important;
        font-weight: 700;
        font-size: 1.15rem;
    }

    .action-hint {
        font-size: 0.8rem;
        color: var(--brand-primary);
        font-weight: 600;
        transition: transform 0.2s ease;
    }

    .food-card:hover .action-hint {
        color: var(--brand-cyan);
        transform: translateX(4px);
    }

    /* Modal Styling */
    .food-modal {
        border: none;
        border-radius: 24px;
        padding: 0;
        width: 90%;
        max-width: 800px;
        background: transparent;
        opacity: 0;
        transform: scale(0.95) translateY(20px);
        overflow: hidden;
        outline: none;
    }

    .food-modal[open] {
        animation: modalFadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .food-modal.closing {
        animation: modalFadeOut 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .food-modal::backdrop {
        background: rgba(0, 0, 0, 0);
        backdrop-filter: blur(0px);
    }

    .food-modal[open]::backdrop {
        animation: backdropFadeIn 0.4s ease forwards;
    }

    .food-modal.closing::backdrop {
        animation: backdropFadeOut 0.3s ease forwards;
    }

    @keyframes modalFadeIn {
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    @keyframes modalFadeOut {
        to {
            opacity: 0;
            transform: scale(0.95) translateY(20px);
        }
    }

    @keyframes backdropFadeIn {
        to {
            background: rgba(4, 6, 10, 0.85);
            backdrop-filter: blur(8px);
        }
    }

    @keyframes backdropFadeOut {
        to {
            background: rgba(0, 0, 0, 0);
            backdrop-filter: blur(0px);
        }
    }

    .modal-content {
        position: relative;
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }

    .close-btn {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(255, 255, 255, 0.08);
        color: var(--text-primary);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 50%;
        width: 38px;
        height: 38px;
        font-size: 1.5rem;
        font-weight: 300;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 20;
        transition: all 0.2s;
    }

    .close-btn:hover {
        background: rgba(236, 72, 153, 0.2);
        color: var(--brand-pink);
        border-color: rgba(236, 72, 153, 0.4);
        transform: scale(1.08) rotate(90deg);
    }

    .modal-split {
        display: flex;
        flex-direction: row;
    }

    .modal-image-col {
        width: 45%;
        position: relative;
        background: #090e1a;
    }

    .modal-img {
        width: 100%;
        height: 100%;
        min-height: 420px;
        object-fit: cover;
    }

    .modal-img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, transparent 70%, rgba(15, 23, 42, 0.9) 100%);
    }

    .modal-info-col {
        width: 55%;
        padding: 3rem 2.5rem 2.5rem 2.5rem;
        display: flex;
        flex-direction: column;
        background: rgba(15, 23, 42, 0.95);
    }

    .modal-category {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--brand-cyan);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
    }

    .modal-title {
        margin: 0 0 10px 0;
        font-size: 2.25rem;
        color: var(--text-primary);
        font-weight: 800;
        line-height: 1.2;
    }

    .modal-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 1.25rem;
    }

    .modal-precio {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--brand-cyan);
        margin-bottom: 1.5rem;
    }

    .modal-desc {
        color: var(--text-secondary);
        line-height: 1.7;
        font-size: 0.95rem;
        margin: 0 0 2rem 0;
        flex-grow: 1;
    }

    .compra-section {
        background: rgba(8, 12, 20, 0.5);
        padding: 1.25rem;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .opciones-title {
        margin: 0 0 0.85rem 0;
        color: var(--text-primary);
        font-size: 0.95rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-family: 'Fira Code', monospace;
    }

    .compra-controls {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .cantidad-selector {
        display: flex;
        align-items: center;
        background: rgba(15, 23, 42, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        height: 44px;
        box-sizing: border-box;
    }

    .qty-btn {
        background: transparent;
        border: none;
        width: 38px;
        height: 100%;
        font-size: 1.2rem;
        font-weight: bold;
        color: var(--text-secondary);
        cursor: pointer;
        transition: all 0.2s;
    }

    .qty-btn:hover {
        color: var(--brand-cyan);
        background: rgba(255, 255, 255, 0.05);
    }

    .qty-input {
        width: 40px;
        height: 100%;
        text-align: center;
        border: none;
        background: transparent;
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
        outline: none;
    }

    .btn-comprar {
        flex: 1;
        height: 44px;
        background: linear-gradient(135deg, var(--brand-primary), var(--brand-cyan));
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
        box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
    }

    .btn-comprar:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(6, 182, 212, 0.4);
        filter: brightness(1.1);
    }

    .btn-comprar:active {
        transform: translateY(0);
    }

    @media (max-width: 768px) {
        .modal-split {
            flex-direction: column;
        }
        .modal-image-col, .modal-info-col {
            width: 100%;
        }
        .modal-img {
            min-height: 200px;
        }
        .modal-img-overlay {
            background: linear-gradient(to top, rgba(15, 23, 42, 0.95) 10%, rgba(15, 23, 42, 0) 100%);
        }
        .modal-info-col {
            padding: 2rem 1.5rem 1.5rem 1.5rem;
        }
        .compra-controls {
            flex-direction: column;
            align-items: stretch;
        }
        .cantidad-selector {
            justify-content: space-between;
        }
    }
</style>

<script>
    // Configuración interactiva local por cada tarjeta
    const wrappers = document.querySelectorAll('.card-wrapper');

    wrappers.forEach(wrapper => {
        const card = wrapper.querySelector('.food-card');
        const modal = wrapper.querySelector('.food-modal');
        const closeBtn = wrapper.querySelector('.close-btn');
        const minusBtn = wrapper.querySelector('.minus');
        const plusBtn = wrapper.querySelector('.plus');
        const qtyInput = wrapper.querySelector('.qty-input');
        const quickAddBtn = wrapper.querySelector('.quick-add-btn');
        const buyBtn = wrapper.querySelector('.btn-comprar');
        
        const cardId = card.getAttribute('data-id') || '';
        const title = wrapper.querySelector('.titulo')?.textContent || '';
        const priceText = wrapper.querySelector('.precio')?.textContent || '';
        const imgUrl = wrapper.querySelector('.img-container img')?.getAttribute('src') || '';

        // Función para despachar el evento de agregar al carrito
        const addToCart = (cantidad) => {
            const event = new CustomEvent('cart:add', {
                bubbles: true,
                detail: {
                    id: cardId,
                    titulo: title,
                    precio: priceText,
                    imagen: imgUrl,
                    cantidad: cantidad
                }
            });
            window.dispatchEvent(event);
        };

        // Agregar rápido al carrito (1 elemento)
        if (quickAddBtn) {
            quickAddBtn.addEventListener('click', (e) => {
                e.stopPropagation(); // Evita abrir el modal
                addToCart(1);
            });
        }

        // Agregar desde el modal
        if (buyBtn && qtyInput) {
            buyBtn.addEventListener('click', () => {
                const qty = parseInt(qtyInput.value) || 1;
                addToCart(qty);
                closeAnimated();
                qtyInput.value = "1"; // Resetear cantidad
            });
        }

        // Controladores de cantidad en el modal
        if (minusBtn && plusBtn && qtyInput) {
            minusBtn.addEventListener('click', () => {
                let val = parseInt(qtyInput.value) || 1;
                if (val > 1) qtyInput.value = (val - 1).toString();
            });
            plusBtn.addEventListener('click', () => {
                let val = parseInt(qtyInput.value) || 1;
                qtyInput.value = (val + 1).toString();
            });
        }

        // Abrir/Cerrar Modal
        if (card && modal && closeBtn) {
            card.addEventListener('click', (e) => {
                // No abrir si se hizo clic en el botón de agregar rápido
                const target = e.target;
                if (target.closest('.quick-add-btn')) return;
                
                modal.showModal();
            });

            const closeAnimated = () => {
                modal.classList.add('closing');
                const onAnimationEnd = () => {
                    modal.classList.remove('closing');
                    modal.close();
                    modal.removeEventListener('animationend', onAnimationEnd);
                };
                modal.addEventListener('animationend', onAnimationEnd);
            };

            closeBtn.addEventListener('click', closeAnimated);

            // Cerrar al hacer clic en el backdrop
            modal.addEventListener('click', (e) => {
                const dialogDimensions = modal.getBoundingClientRect();
                if (
                    e.clientX < dialogDimensions.left ||
                    e.clientX > dialogDimensions.right ||
                    e.clientY < dialogDimensions.top ||
                    e.clientY > dialogDimensions.bottom
                ) {
                    closeAnimated();
                }
            });
        }
    });
</script>