---
// src/components/ParticleBackground.astro
---

<div id="tsparticles"></div>

<script>
    import { tsParticles } from "@tsparticles/engine";
    import { loadSlim } from "@tsparticles/slim"; // Usamos la versión slim para mejor rendimiento

    // Función autoejecutable para la inicialización
    (async () => {
        await loadSlim(tsParticles); // Cargar los motores necesarios

        await tsParticles.load({
            id: "tsparticles",
            options: {
                background: {
                    color: "#080c14",
                },
                fpsLimit: 60,
                interactivity: {
                    events: {
                        onClick: {
                            enable: false,
                        },
                        onHover: {
                            enable: true,
                            mode: "grab",
                        },
                        resize: true,
                    },
                    modes: {
                        grab: {
                            distance: 180,
                            links: {
                                opacity: 0.6,
                            },
                        },
                    },
                },
                particles: {
                    color: {
                        value: ["#6366f1", "#06b6d4", "#ec4899"], // Indigo, Cyan, Pink neon dots
                    },
                    links: {
                        color: "#312e81", // Subtle dark indigo connection lines
                        distance: 130,
                        enable: true,
                        opacity: 0.4,
                        width: 1,
                    },
                    collisions: {
                        enable: false,
                    },
                    move: {
                        direction: "none",
                        enable: true,
                        outModes: {
                            default: "bounce",
                        },
                        random: true,
                        speed: 0.8,
                        straight: false,
                    },
                    number: {
                        density: {
                            enable: true,
                            area: 800,
                        },
                        value: 90,
                    },
                    opacity: {
                        value: { min: 0.2, max: 0.6 },
                    },
                    shape: {
                        type: "circle",
                    },
                    size: {
                        value: { min: 1, max: 3 },
                    },
                },
                detectRetina: true,
            },
        });
    })();
</script>

<style>
    #tsparticles {
        position: fixed; /* Fijo para que cubra todo */
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1; /* Detrás de todo el contenido */
    }
</style>